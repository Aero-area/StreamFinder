{
  "manifest_version": 3,
  "name": "StreamFinder",
  "version": "2.0.3",
  "description": "Find downloadable media URLs on the current website and download the source file.",
  "permissions": ["activeTab", "downloads", "scripting", "tabs", "webRequest", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "StreamFinder",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
